{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": false,
    "types": ["@cloudflare/workers-types"]
  },
  "include": ["src/**/*"],
  // 테스트는 node:test(Node 타입)라 워커 타입셋과 분리. 실행/검증은 `node --test`가 담당.
  "exclude": ["src/**/*.test.ts"]
}
